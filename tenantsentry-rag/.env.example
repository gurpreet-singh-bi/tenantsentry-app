# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Voyage AI (embeddings)
VOYAGE_API_KEY=pa-your-key-here

# Supabase (vector store — use Sydney region: ap-southeast-2)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ-your-service-key-here

# AWS (only needed for Textract OCR fallback on scanned PDFs)
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=ap-southeast-2

# Admin portal (G4 — human-in-loop review gate)
# Set a strong random secret. Never commit the real value.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=changeme-set-a-strong-secret

# App config
LOG_LEVEL=INFO
MAX_CHUNKS_PER_RETRIEVAL=8
OPUS_MODEL=claude-opus-4-6
SONNET_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=voyage-large-2-instruct
EMBEDDING_DIMENSION=1024
