# ══════════════════════════════════════════════════════
# TenantSentry.ai — Environment Configuration
# Copy to .env and fill in real values before deploying.
# NEVER commit .env with real secrets.
# ══════════════════════════════════════════════════════

# ── Anthropic (Claude API) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Voyage AI (embeddings) ────────────────────────────
VOYAGE_API_KEY=pa-your-key-here

# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ-your-service-key-here

# ── AWS (Textract OCR — scanned PDFs only) ────────────
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=ap-southeast-2

# ── Claude model identifiers (confirmed valid 2026-06-01) ──
OPUS_MODEL=claude-opus-4-6
SONNET_MODEL=claude-sonnet-4-6

# ── Embedding config ──────────────────────────────────
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSION=1024
MAX_CHUNKS_PER_RETRIEVAL=8

# ── App config ────────────────────────────────────────
LOG_LEVEL=INFO

# ── MODE: DEV or LIVE ────────────────────────────────
# DEV_MODE=true  → Dev mode:  zero API calls, deterministic mock data, free
# DEV_MODE=false → Live mode: real Claude API, Supabase, VoyageAI
# Toggle at runtime via the DEV/LIVE button in the nav (admin token required).
# ⚠️  MUST be false (Live) in production
DEV_MODE=true

# ── Portal tokens — generate unique values before deploying ──────────────────
# python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# ADMIN_TOKEN   → admin.tenantsentry.ai  (internal auditor portal, separate subdomain)
# PARTNER_TOKEN → tenantsentry.ai/partners/login  (channel partner portal)
#
# ⚠️  Use different, strong random values for each in production.
#     These are dev-only defaults — never ship with these values.
ADMIN_TOKEN=changeme-set-a-strong-secret
PARTNER_TOKEN=partner-changeme-set-a-strong-secret
